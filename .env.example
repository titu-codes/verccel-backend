# Database - REQUIRED for Railway & Vercel (SQLite does NOT persist!)

# Railway: Add PostgreSQL from Dashboard -> + New -> Database -> PostgreSQL
# Then add DATABASE_URL variable (reference from PostgreSQL service)

# Option 1: PostgreSQL (Railway, Neon, Supabase)
# DATABASE_URL=postgresql://user:password@host:port/database

# Option 2: MySQL (Aiven, PlanetScale)
# DATABASE_URL=mysql+pymysql://user:password@host:port/database

# Option 3: SQLite for LOCAL dev only
USE_SQLITE=true
