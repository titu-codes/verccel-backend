# Database - REQUIRED for Vercel (SQLite does NOT persist on serverless!)

# Option 1: PostgreSQL (Neon, Supabase, Vercel Postgres) - RECOMMENDED for Vercel
# Add Neon from Vercel Marketplace, then POSTGRES_URL is auto-set
# Or: DATABASE_URL=postgresql://user:password@host:port/database

# Option 2: MySQL (Aiven, Railway, PlanetScale)
# DATABASE_URL=mysql+pymysql://user:password@host:port/database

# Option 3: SQLite for local dev only (data vanishes on Vercel!)
USE_SQLITE=true
